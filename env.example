# ============================================================
# python-training-fundamentals — Plantilla de variables de entorno
# ============================================================
#
# CÓMO USAR ESTE ARCHIVO:
#
# 1. Copia este archivo a .env (sin la palabra "example"):
#       cp env.example .env
#
# 2. Llena los valores que necesitas. La mayoría de módulos NO necesitan
#    ninguna variable — solo a partir de M4 (persistencia) y M5 (API)
#    necesitas la base de datos configurada.
#
# 3. NO subas el .env real a git. El .gitignore lo excluye.
#
# FORMATO DE VARIABLES:
#   - Sin comillas alrededor de los valores: KEY=valor
#   - Sin espacios alrededor del =:           KEY=valor   (correcto)
#                                             KEY = valor (incorrecto)
#   - Sin punto y coma al final
#   - Para valores con espacios o caracteres especiales,
#     usa comillas dobles: KEY="mi valor con espacios"
#   - Líneas que empiezan con # son comentarios
#
# ============================================================


# =============================================================
# BASE DE DATOS — desde Módulo 4 (Async, HTTP y persistencia)
# =============================================================

# PostgreSQL — base de datos relacional para el proyecto integrador.
# Si usas el docker-compose.yml del curso, estos valores funcionan tal cual.
POSTGRES_USER=curso
POSTGRES_PASSWORD=curso
POSTGRES_DB=tiendapro
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://curso:curso@localhost:5432/tiendapro


# =============================================================
# API — desde Módulo 5 (FastAPI)
# =============================================================

# Puerto en el que corre la API del proyecto integrador
API_PORT=8000
API_HOST=0.0.0.0

# Modo de ejecución: "development" | "production"
APP_ENV=development

# Nivel de logs: "DEBUG" | "INFO" | "WARNING" | "ERROR"
LOG_LEVEL=INFO
